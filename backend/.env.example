# LLM Provider: "openai", "gemini", or "groq"
LLM_PROVIDER=gemini

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (used if LLM_PROVIDER=gemini, or as GROQ_EMBEDDING_PROVIDER)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=3072

# Groq (used if LLM_PROVIDER=groq) - chat only, no embeddings API.
# Groq needs OPENAI_API_KEY or GOOGLE_API_KEY set for embeddings (see GROQ_EMBEDDING_PROVIDER).
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_EMBEDDING_PROVIDER=gemini

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
RETRIEVER_TOP_K=4

# Storage
UPLOAD_DIR=data/uploads
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=pdf_documents
LOCAL_VECTORSTORE_PATH=data/vectorstore.json

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
